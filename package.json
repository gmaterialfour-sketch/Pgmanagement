{
  "name": "pg-rental-saas",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspaces --if-present",
    "dev:backend": "npm run dev -w @pg-rental/backend",
    "dev:backend-java": "powershell.exe -File ./run-java.ps1",
    "dev:web": "npm run dev -w @pg-rental/web",
    "dev:mobile": "npm run start -w @pg-rental/mobile",
    "build": "npm run build --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "db:generate": "npm run prisma:generate -w @pg-rental/backend",
    "db:migrate": "npm run prisma:migrate -w @pg-rental/backend",
    "db:seed": "npm run seed -w @pg-rental/backend"
  },
  "devDependencies": {
    "typescript": "^5.6.3"
  }
}
